{
  "name": "40k-vtt",
  "version": "1.0.0",
  "private": true,
  "description": "Warhammer 40K 11th Edition — assisted virtual tabletop (unofficial, not affiliated with Games Workshop)",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite -c client/vite.config.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build -c client/vite.config.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "ingest": "tsx scripts/ingest-wahapedia.ts",
    "ingest:40kdc": "tsx scripts/ingest-40kdc.ts",
    "seed": "tsx scripts/seed-sample.ts"
  },
  "dependencies": {
    "csv-parse": "^5.6.0",
    "express": "^4.21.2",
    "fast-levenshtein": "^3.0.0",
    "nanoid": "^5.0.9",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "zustand": "^5.0.3"
  }
}
